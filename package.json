{
  "name": "along-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite --config play/vite.config.ts",
    "dev:docs": "vitepress dev docs",
    "build": "pnpm build:full && pnpm build:components",
    "build:full": "vite build -c internal/build/vite.full.config.ts",
    "build:components": "vite build -c internal/build/vite.components.config.ts",
    "build:docs": "vitepress build docs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "sass": "^1.77.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitepress": "^1.5.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
